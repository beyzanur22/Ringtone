<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 1. POPUP MENÜ STİLLERİ -->
    <style name="CustomPopupMenu" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@drawable/bg_popup_dark</item>
        <item name="popupMenuBackground">@drawable/bg_popup_dark</item>
        <item name="android:colorBackground">#2B2B2B</item>
        
        <item name="textAppearanceLargePopupMenu">@style/CustomPopupText</item>
        <item name="textAppearanceSmallPopupMenu">@style/CustomPopupText</item>
        
        <item name="android:listPreferredItemHeightSmall">36dp</item>
        <item name="listPreferredItemHeightSmall">36dp</item>
        
    </style>

    <style name="CustomPopupText" parent="TextAppearance.AppCompat.Widget.PopupMenu.Small">
        <item name="android:textColor">#EAE8E8</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CustomNavigationView" parent="Widget.MaterialComponents.NavigationView">
        <item name="itemVerticalPadding">6dp</item>
        <item name="itemHorizontalPadding">16dp</item>
        <item name="itemIconSize">20dp</item>
    </style>

    <!-- 2. BU YENİ: ALERT DIALOG (PLAYLIST SEÇME EKRANI) İÇİN STİL -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_popup_dark</item>
        <item name="android:colorBackground">#2B2B2B</item>
        
        <item name="android:textColorPrimary">#FFFFFF</item> <!-- Dialog başlık rengi -->
        <item name="android:textColorSecondary">#EAE8E8</item> <!-- Dialog alt metin rengi -->
        <item name="android:textColorAlertDialogListItem">#EAE8E8</item> <!-- Liste içi yazı (Beyza gibi) -->
        
        <!-- Yüksekliği/boyutu da küçültmek için font boyutu düşürüyoruz -->
        <item name="android:textSize">13sp</item>
        <item name="buttonBarButtonStyle">@style/CustomDialogButton</item>
    </style>

    <style name="CustomDialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#00E676</item> <!-- Cancel/OK buton rengi: İsterseniz #FFFFFF yapın -->
        <item name="android:textSize">12sp</item>
    </style>

</resources>
