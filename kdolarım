    private fun showPlaylists() {
        lifecycleScope.launch(Dispatchers.IO) {

            val playlists = db.dao().getPlaylists()

            val playlistsWithDetails = playlists.map { playlist ->
                val count = db.dao().getTrackCount(playlist.id)
                val tracks = db.dao().getTracksForPlaylist(playlist.id)
                val thumb = tracks.firstOrNull()?.thumbnailUrl
                val titles = tracks.take(3).map { it.title }

                Triple(playlist, count, Pair(thumb, titles))
            }

            withContext(Dispatchers.Main) {
                downloadViewPager.visibility = View.GONE
                tabContainer.visibility = View.GONE
                recyclerView.visibility = View.VISIBLE

                txtToolbarTitle.text = "Playlists"
                txtToolbarSubtitle.text = ""

                recyclerView.layoutManager =
                    LinearLayoutManager(this@MainActivity)

                recyclerView.adapter = PlaylistsAdapter(
                    items = playlistsWithDetails,
                    onClick = { playlist ->
                        openPlaylist(playlist.id, playlist.name)
                    },
                    onCreate = {
                        showCreatePlaylistDialog()
                    },
                    onDelete = { playlist ->

