        val isAudio = suffix.endsWith(".m4a")

        val active = ActiveDownload(
            title = video.title,
            thumbnailUrl = video.thumbnailUrl,
            duration = formatDuration(seconds = video.duration),
            url = video.url,
            fileName = "$safe$suffix",
            artist = video.uploader ?: "Unknown Artist",
            isAudio = isAudio
        )

        activeDownloads.add(active)
        activeAdapter.notifyDataSetChanged()
        updateDownloadBadge()
        updateDownloadBar()
        updateDownloadPanelState()

        lifecycleScope.launch(Dispatchers.IO) {

            try {

                // URL temizleme
                val uri = android.net.Uri.parse(video.url)

                val videoId = uri.getQueryParameter("v")
                    ?: uri.lastPathSegment   // shorts fallback

                if (videoId == null) {
                    withContext(Dispatchers.Main) {
                        Toast.makeText(
                            this@MainActivity,
                            "Video ID çözülemedi",
                            Toast.LENGTH_SHORT
                        ).show()
                    }
                    return@launch
                }


                val base = "https://ringtone-production.up.railway.app"

                var directUrl: String? = null

                //  Android 13 ve üstü ise ÖNCE NEWPIPE DENE (Sadece 4 saniye ver)
                if (android.os.Build.VERSION.SDK_INT >= 33) {
                    directUrl = kotlinx.coroutines.withTimeoutOrNull(4000L) {
                        val api = MediaApi(this@MainActivity)
                        if (isAudio) api.getAudioUrl(videoId) else api.getVideoUrl(videoId)
                    }
                }

                val fileName = if (isAudio) "$safe.m4a" else "$safe.mp4"

                if (!directUrl.isNullOrEmpty()) {

                    //  EN TEMİZ YOL (YouTube fark etmez, cihazdan indir)
                    downloadToAppFolder(directUrl, "$safe$suffix", active)

                } else {

                    //  FALLBACK (Railway Backend - Çok Güvenilir ve Hızlı)
                    val streamUrl = if (isAudio) {
                        "$base/download/mp3?videoId=$videoId"
                    } else {
                        "$base/download/mp4?videoId=$videoId"
                    }

                    downloadToAppFolder(streamUrl, "$safe$suffix", active)

                    withContext(Dispatchers.Main) {

                    }
                }

                withContext(Dispatchers.Main) {
                    activeAdapter.notifyDataSetChanged()
                    refreshDownloadsList()

