        if (!isBound) {
            Toast.makeText(this, "Music service not ready", Toast.LENGTH_SHORT).show()
            return
        }

        currentTrackList = trackList
        currentTrackIndex = trackList.indexOf(track)

        if (track.streamUrl.startsWith("/")) {
            playLocalAudio(
                File(track.streamUrl),
                track.thumbnailUrl
            )
        } else {
            playYoutubeAudio(track)
        }
    }
    private fun playYoutubeAudio(track: TrackEntity) {

        //  1) URL null / boş kontrolü
        if (track.streamUrl.isBlank()) {
            Toast.makeText(this, "Video linki boş", Toast.LENGTH_SHORT).show()
            return
        }
        //  2) youTube watch linki kontrolü
        if (!track.streamUrl.contains("youtube.com")) {
            Toast.makeText(this, "Geçersiz YouTube linki", Toast.LENGTH_SHORT).show()
            return
        }

        miniPlayer.visibility = View.VISIBLE
        miniPlayerTitle.text = "Hazırlanıyor: ${track.title}..."
        miniPlayerTitle.isSelected = true
        miniPlayerArtist.text = ""

        lifecycleScope.launch(Dispatchers.IO) {

            try {

                //  DEBUG için log ekle
                android.util.Log.d("STREAM_URL_DEBUG", track.streamUrl)
               //ÖNEMLİ ALAN
                val uri = android.net.Uri.parse(track.streamUrl)

                val videoId = uri.getQueryParameter("v")
                    ?: uri.lastPathSegment  // shorts fallback

                if (videoId == null) {
                    withContext(Dispatchers.Main) {
                        Toast.makeText(this@MainActivity, "Video ID çözülemedi", Toast.LENGTH_SHORT).show()
                    }
                    return@launch
                }



                var audioUrl = StreamCache.get(videoId)

                if (audioUrl == null) {
                    // Android 13 (API 33) ve üstü ise NewPipe dene (kısa süre), altıysa direkt Backend
                    if (android.os.Build.VERSION.SDK_INT >= 33) {
                        // Sadece 3 saniye süre veriyoruz. Çözerse çözer, çözemezse direkt hızlı backend.
                        audioUrl = kotlinx.coroutines.withTimeoutOrNull(3000L) {
                            MediaApi(this@MainActivity).getAudioUrl(videoId)
                        }
                    }

                    if (audioUrl.isNullOrEmpty()) {
                        // NewPipe başarısız oldu, vakit aşımı VEYA Cihaz Android 12 ve altı!
                        audioUrl = "https://ringtone-production.up.railway.app/stream?videoId=$videoId"
                    } else {
                        StreamCache.put(videoId, audioUrl)
                    }
                }
                withContext(Dispatchers.Main) {
                    val metadata = MediaMetadata.Builder()
                        .setTitle(track.title)
                        .setArtist(track.uploader)
                        .setArtworkUri(Uri.parse(track.thumbnailUrl)) // Kapak resmi
                        .build()

                    // Servise sadece URL değil, metadata ile birlikte gönderiyoruz
                    musicService?.play(audioUrl, videoId , metadata)
                    miniPlayerTitle.text = track.title
                    miniPlayerTitle.isSelected = true
                    miniPlayerArtist.text = track.uploader ?: "Unknown"

                    Glide.with(this@MainActivity)
                        .load(track.thumbnailUrl)
                        .into(miniPlayerCover)

                    findViewById<ImageButton>(R.id.btnPlayPause)
                        .setImageResource(android.R.drawable.ic_media_pause)

                    updateMiniPlayerVisibility()
                    startMiniPlayerProgressUpdater()
                }

            } catch (e: Exception) {
                e.printStackTrace()

                withContext(Dispatchers.Main) {
                    Toast.makeText(
                        this@MainActivity,
                        "Video açılırken hata oluştu",
                        Toast.LENGTH_SHORT
                    ).show()
                }
            }
        }
    }
