            btnPlayPause.setImageResource(android.R.drawable.ic_media_play)
        }
        // Mevcut çalan bilgileri doldur
        txtTitle.text = miniPlayerTitle.text

        // Eğer YouTube track ise thumbnail al
        if (currentTrackIndex >= 0 && currentTrackIndex < currentTrackList.size) {

            val track = currentTrackList[currentTrackIndex]

            txtArtist.text = track.uploader ?: "Unknown"

            if (!track.thumbnailUrl.isNullOrEmpty()) {
                Glide.with(this)
                    .load(track.thumbnailUrl)
                    .into(imgCover)
            } else {
                imgCover.setImageResource(android.R.drawable.ic_media_play)            }

        } else {
            txtArtist.text = "Local file"
            imgCover.setImageResource(android.R.drawable.ic_media_play)        }

        // Play / Pause
        btnPlayPause.setOnClickListener {
            if (musicService?.isPlaying() == true) {
                musicService?.pause()
            } else {
                musicService?.resume()
            }
        }
        //  Next
        btnNext.setOnClickListener {

            if (currentTrackList.isEmpty()) return@setOnClickListener

            currentTrackIndex = if (isShuffleEnabled) {
                (0 until currentTrackList.size).random()
            } else {
                currentTrackIndex + 1
            }

            if (currentTrackIndex >= currentTrackList.size) {
                currentTrackIndex = currentTrackList.size - 1
                return@setOnClickListener
            }

            playTrack(
                currentTrackList[currentTrackIndex],
                currentTrackList
            )

            dialog.dismiss()
        }

        // Prev
        btnPrev.setOnClickListener {

            if (currentTrackList.isEmpty()) return@setOnClickListener

            currentTrackIndex = if (isShuffleEnabled) {
                (0 until currentTrackList.size).random()
            } else {
                currentTrackIndex - 1
            }

            if (currentTrackIndex < 0) {
                currentTrackIndex = 0
                return@setOnClickListener
            }

            playTrack(
                currentTrackList[currentTrackIndex],
                currentTrackList
            )

            dialog.dismiss()
        }
        btnForward3.setOnClickListener {

            isShuffleEnabled = !isShuffleEnabled

            if (isShuffleEnabled) {
                btnForward3.setColorFilter(android.graphics.Color.GREEN)
                Toast.makeText(this, "Shuffle On", Toast.LENGTH_SHORT).show()
            } else {
                btnForward3.setColorFilter(android.graphics.Color.WHITE)
                Toast.makeText(this, "Shuffle Off", Toast.LENGTH_SHORT).show()
            }
        }
        btnRestart.setOnClickListener {

            repeatMode++

            if (repeatMode > 2) repeatMode = 0

            when (repeatMode) {

                0 -> {
                    btnRestart.setImageResource(R.drawable.ic_repeat)
                    btnRestart.setColorFilter(android.graphics.Color.WHITE)
                    Toast.makeText(this, "Repeat Off", Toast.LENGTH_SHORT).show()
                }

                1 -> {
                    btnRestart.setImageResource(R.drawable.ic_repeat_active)
                    btnRestart.setColorFilter(android.graphics.Color.GREEN)
                    Toast.makeText(this, "Repeat Playlist", Toast.LENGTH_SHORT).show()
                }

                2 -> {
                    btnRestart.setImageResource(R.drawable.ic_repeat_one)
                    btnRestart.setColorFilter(android.graphics.Color.GREEN)
                    Toast.makeText(this, "Repeat One", Toast.LENGTH_SHORT).show()
                }
            }
        }
        //  Süre Güncelleme
        val handler = android.os.Handler(mainLooper)
        val updateRunnable = object : Runnable {
            override fun run() {

                val position = musicService?.getCurrentPosition() ?: 0L
                val duration = musicService?.getDuration() ?: 0L

                if (duration > 0) {
                    seekBar.max = duration.toInt()
                    seekBar.progress = position.toInt()

                    txtCurrentTime.text = formatTime(position)
                    txtTotalTime.text = formatTime(duration)

                }
                handler.postDelayed(this, 1000)
            }
        }

        handler.post(updateRunnable)

        //  SeekBar kontrol
        seekBar.setOnSeekBarChangeListener(object : SeekBar.OnSeekBarChangeListener {

            override fun onProgressChanged(seekBar: SeekBar?, progress: Int, fromUser: Boolean) {
                if (fromUser) {
                    musicService?.seekTo(progress.toLong())
                }
            }

            override fun onStartTrackingTouch(seekBar: SeekBar?) {}

            override fun onStopTrackingTouch(seekBar: SeekBar?) {}
        })
        dialog.setOnDismissListener {
            updateMiniPlayerVisibility()
            handler.removeCallbacks(updateRunnable)
        }
        dialog.show()

        val bottomSheet =
            dialog.findViewById<View>(
                com.google.android.material.R.id.design_bottom_sheet
            )

        bottomSheet?.let {

            it.layoutParams.height =
                ViewGroup.LayoutParams.MATCH_PARENT

            val behavior =
                com.google.android.material.bottomsheet.BottomSheetBehavior.from(it)

            behavior.state =
                com.google.android.material.bottomsheet.BottomSheetBehavior.STATE_EXPANDED

            behavior.skipCollapsed = true
        }
        musicService?.getPlayer()?.addListener(object : Player.Listener {

            override fun onIsPlayingChanged(isPlaying: Boolean) {

                if (isPlaying) {
                    btnPlayPause.setImageResource(android.R.drawable.ic_media_pause)
                } else {
                    btnPlayPause.setImageResource(android.R.drawable.ic_media_play)
                }

            }

        })
    }
    private fun formatTime(ms: Long): String {
        val totalSeconds = ms / 1000
        val minutes = totalSeconds / 60
        val seconds = totalSeconds % 60
        return String.format("%02d:%02d", minutes, seconds)
    }
    override fun onDestroy() {

        unregisterReceiver(trackEndedReceiver)

        if (isBound) {
            unbindService(serviceConnection)
            isBound = false
        }

        super.onDestroy()
    }
