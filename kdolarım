        if (isBound && currentTrackIndex >= 0 && currentTrackList.isNotEmpty()) {
            miniPlayer.visibility = View.VISIBLE
        } else {
            miniPlayer.visibility = View.GONE
        }
    }
    private fun parseIsoDuration(iso: String): Long {
        val regex = Regex("PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?")
        val match = regex.find(iso) ?: return 0L

        val hours = match.groups[1]?.value?.toLongOrNull() ?: 0
        val minutes = match.groups[2]?.value?.toLongOrNull() ?: 0
        val seconds = match.groups[3]?.value?.toLongOrNull() ?: 0

        return hours * 3600 + minutes * 60 + seconds

    }
    fun updateDownloadBar() {

        val downloadingItems =
            activeDownloads.filter { it.state == DownloadState.DOWNLOADING }

        if (downloadingItems.isEmpty()) {

            downloadBar.setBackgroundResource(R.drawable.bg_download_normal)

            downloadBar.visibility = View.VISIBLE

            txtDownloadBarText.text = "="
            txtDownloadBarText.gravity = android.view.Gravity.CENTER
            txtDownloadBarText.isSelected = false

            findViewById<TextView>(R.id.txtDownloadPercentRight).text = ""

        } else {

            val latestDownload = downloadingItems.last()
            val progress = latestDownload.progress

            downloadBar.setBackgroundResource(R.drawable.bg_download_active)

            downloadBar.visibility = View.VISIBLE

            val artist = latestDownload.artist ?: "Unknown"
            val title = latestDownload.title ?: ""

            //  karakter limiti
            val fullText = "     Fetching $artist - $title"
            val limitedText =
                if (fullText.length > 30)
                    fullText.take(30)
                else fullText

            txtDownloadBarText.text = limitedText
            txtDownloadBarText.gravity = android.view.Gravity.START
            txtDownloadBarText.isSelected = true

            findViewById<TextView>(R.id.txtDownloadPercentRight).text = "%$progress     "
        }
        downloadBar.requestLayout()
    }
