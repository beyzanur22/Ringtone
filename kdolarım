    private fun downloadToAppFolder(
        url: String,
        name: String,
        active: ActiveDownload
    ) {
        lifecycleScope.launch(Dispatchers.IO) {
            try {

                val dir = File(getExternalFilesDir(null), "downloads")
                if (!dir.exists()) dir.mkdirs()

                val outFile = File(dir, name)

                val request = Request.Builder()
                    .url(url)
                    .addHeader("X-App-Key", "RINGTONE_MASTER_V2_SECRET_2026")
                    .build()

                val call = httpClient.newCall(request)

                active.call = call

                val response = call.execute()
                val body = response.body() ?: return@launch

                val total = body.contentLength()
                var downloaded = 0L

                body.byteStream().use { input ->
                    outFile.outputStream().use { output ->

                        val buffer = ByteArray(8192)
                        var read: Int

                        while (input.read(buffer).also { read = it } != -1) {

                            if (active.state == DownloadState.CANCELED) {
                                return@launch
                            }

                            output.write(buffer, 0, read)
                            downloaded += read

                            val progress =
                                if (total > 0) ((downloaded * 100) / total).toInt()
                                else 0

                            active.progress = progress

                            withContext(Dispatchers.Main) {
                                activeAdapter.notifyDataSetChanged()
                                updateDownloadBar()
                                updateDownloadBadge()
                            }
                        }
                    }
                }

                // Dosya boyutu kontrolü — boş/hatalı indirme tespiti
                val minSize = if (active.fileName.endsWith(".m4a")) 50 * 1024L else 500 * 1024L
                if (outFile.length() < minSize) {
                    outFile.delete()
                    active.state = DownloadState.FAILED
                    withContext(Dispatchers.Main) {
                        activeAdapter.notifyDataSetChanged()
                        updateDownloadBar()
                        Toast.makeText(this@MainActivity, "İndirme başarısız — dosya çok küçük", Toast.LENGTH_SHORT).show()
                    }
                    return@launch
                }

                active.state = DownloadState.COMPLETED

                withContext(Dispatchers.Main) {
                    updateDownloadBar()
                }

                val isAudio = active.fileName.endsWith(".m4a")
                //  TELEFON DOWNLOADS KLASÖRÜNE KOPYALA
                val publicFile = File(
                    android.os.Environment.getExternalStoragePublicDirectory(
                        android.os.Environment.DIRECTORY_DOWNLOADS
                    ),
                    name
                )

                outFile.copyTo(publicFile, overwrite = true)
                android.media.MediaScannerConnection.scanFile(
                    this@MainActivity,
                    arrayOf(publicFile.absolutePath),
                    null,
                    null
                )  // Yeni bir medya dosyası geldi, sistemi güncelle. demeye yarar.
                db.dao().insertDownload(
                    DownloadEntity(
                        path = outFile.absolutePath,
                        isAudio = isAudio,
                        thumbnailUrl = active.thumbnailUrl,
                        duration = active.duration
                    )
                )

                withContext(Dispatchers.Main) {
                    activeAdapter.notifyDataSetChanged()
                    refreshDownloadsList()
                    Toast.makeText(this@MainActivity, "${active.title} Downloaded successfully!", Toast.LENGTH_SHORT).show()
                    //  AUDIO ise direkt çal
                    if (isAudio) {
                        playLocalAudio(outFile, active.thumbnailUrl)
                    } else {
                        val intent = Intent(this@MainActivity, VideoPlayerActivity::class.java)
                        intent.putExtra("path", outFile.absolutePath)
                        startActivity(intent)
                    }

                }

            } catch (e: Exception) {
                e.printStackTrace()
            }

        }
    }

