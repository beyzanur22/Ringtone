    private fun startMiniPlayerProgressUpdater() {
        miniHandler?.removeCallbacksAndMessages(null)
        miniHandler = android.os.Handler(mainLooper)
        miniRunnable = object : Runnable {
            override fun run() {
                val position = musicService?.getCurrentPosition() ?: 0L
                val duration = musicService?.getDuration() ?: 0L

                if (duration > 0) {
                    val progressPercent = ((position * 100) / duration).toInt()
                    miniPlayerProgress.progress = progressPercent
                }

                miniHandler?.postDelayed(this, 500)
            }
        }
        miniHandler?.post(miniRunnable!!)
    }
    private fun loadNextPage() {

        isLoadingMore = true

        Thread {

            try {

                val url =
                    "https://ringtone-production.up.railway.app/search?q=" +
                            java.net.URLEncoder.encode(currentQuery, "UTF-8") +
                            "&pageToken=$nextPageToken"

                val request = Request.Builder()
                    .url(url)
                    .addHeader("X-App-Key", "RINGTONE_MASTER_V2_SECRET_2026")
                    .build()

                val response = OkHttpClient().newCall(request).execute()

                val body = response.body()?.string() ?: return@Thread

                val jsonObject = JSONObject(body)

                nextPageToken = jsonObject.optString("nextPageToken", null)

                val items = jsonObject.getJSONArray("data")

                for (i in 0 until items.length()) {

                    val item = items.getJSONObject(i)
                    val snippet = item.getJSONObject("snippet")

                    val videoId = if (item.get("id") is String) {
                        item.getString("id")
                    } else {
                        item.getJSONObject("id").getString("videoId")
                    }

                    val title = snippet.getString("title")
                    val channel = snippet.getString("channelTitle")

                    val thumbnail = snippet
                        .getJSONObject("thumbnails")
                        .getJSONObject("high")
                        .getString("url")

                    searchResults.add(
                        VideoModel(
                            title,
                            channel,
                            "https://www.youtube.com/watch?v=$videoId",
                            thumbnail,
                            0L
                        )
                    )
                }

                runOnUiThread {

                    recyclerView.adapter?.notifyDataSetChanged()

                    isLoadingMore = false
                }

            } catch (e: Exception) {

                isLoadingMore = false

            }

        }.start()
    }
    private val trackEndedReceiver = object : BroadcastReceiver() {
        override fun onReceive(context: Context?, intent: Intent?) {

            when (repeatMode) {

                2 -> {
                    // repeat one
                    musicService?.seekTo(0)
                    musicService?.resume()
                }

                else -> {
                    playNextTrack()
                }
            }
        }
    }
    private fun playNextTrack() {

        if (currentTrackList.isEmpty()) return

        if (repeatMode == 1 && currentTrackIndex == currentTrackList.size - 1) {
            currentTrackIndex = 0
        } else {
            currentTrackIndex++
        }

        if (currentTrackIndex >= currentTrackList.size) return

        playTrack(
            currentTrackList[currentTrackIndex],
            currentTrackList
        )
    }
    fun downloadWithManager(url: String, fileName: String) {

        val request = android.app.DownloadManager.Request(Uri.parse(url))
            .addRequestHeader("X-App-Key", "RINGTONE_MASTER_V2_SECRET_2026")
            .setTitle(fileName)
            .setDescription("Downloading...")

            .setMimeType(
                if (fileName.endsWith(".m4a")) "audio/mp4" else "video/mp4"
            )

            .setAllowedOverMetered(true)
            .setAllowedOverRoaming(true)

            .setNotificationVisibility(
                android.app.DownloadManager.Request.VISIBILITY_VISIBLE_NOTIFY_COMPLETED
            )
            .setDestinationInExternalPublicDir(
                android.os.Environment.DIRECTORY_DOWNLOADS,
                fileName
            )

        val dm = getSystemService(Context.DOWNLOAD_SERVICE) as android.app.DownloadManager
        dm.enqueue(request)
    }
