    private fun fetchRemoteConfig(onResult: (AppConfig) -> Unit) {

        Thread {
            try {
                val url = URL("https://ringtone-production.up.railway.app/config")
                val connection = url.openConnection() as HttpURLConnection
                connection.connectTimeout = 15000
                connection.readTimeout = 15000

                connection.requestMethod = "GET"
                connection.setRequestProperty(
                    "X-App-Key",
                    "RINGTONE_MASTER_V2_SECRET_2026"
                )

                val reader = BufferedReader(
                    InputStreamReader(connection.inputStream)
                )

                val response = reader.readText()
                val json = org.json.JSONObject(response)
                val globalJson = json.getJSONObject("global")
                val countriesJson = json.getJSONObject("countries")
                val countriesMap = mutableMapOf<String, String>()

                val keys = countriesJson.keys()
                while (keys.hasNext()) {
                    val key = keys.next()
                    countriesMap[key] = countriesJson.getString(key)
                }

                val config = AppConfig(
                    global = GlobalConfig(
                        enabled = globalJson.getBoolean("enabled"),
                        mode = globalJson.getString("mode")
                    ),
                    countries = countriesMap
                )
                runOnUiThread {
                    onResult(config)
                }

            } catch (e: Exception) {
                e.printStackTrace()
            }
        }.start()
    }
