    private fun playLocalAudio(file: File, thumbnailUrl: String?) {

        val uriString = "file://${file.absolutePath}"
        val metadata = MediaMetadata.Builder()
            .setTitle(
                file.name
                    .replace("_audio.webm", "")
                    .replace("_audio.m4a", "")
                    .replace("_audio.mp3", "")
            )
            .setArtist("Local File")
            .apply {
                if (!thumbnailUrl.isNullOrEmpty()) {
                    setArtworkUri(Uri.parse(thumbnailUrl))
                }
            }
            .build()
        musicService?.play(uriString,null, metadata)

        miniPlayer.visibility = View.VISIBLE
        miniPlayerTitle.text = file.name
        miniPlayerTitle.isSelected = true
        miniPlayerArtist.text = "Local file"

        if (!thumbnailUrl.isNullOrEmpty()) {
            Glide.with(this)
                .load(thumbnailUrl)
                .into(miniPlayerCover)
        }

        updateMiniPlayerVisibility()
        startMiniPlayerProgressUpdater()
    }

    private fun openLocalVideo(file: java.io.File) {
        startActivity(
            Intent(this, VideoPlayerActivity::class.java)
                .putExtra("path", file.absolutePath)
        )
    }

