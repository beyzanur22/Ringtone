        if (activeDownloads.isEmpty()) {
            emptyStateLayout.visibility = View.VISIBLE
            downloadsPanelRecycler.visibility = View.GONE
            btnClearDownloads.visibility = View.GONE
        } else {
            emptyStateLayout.visibility = View.GONE
