    private fun fetchTop50() {

        val url = "https://ringtone-production.up.railway.app/top50"
        txtToolbarTitle.text = "Home"
        txtToolbarSubtitle.text = "Popular"
        loadingLayout.visibility = View.VISIBLE
        Thread {
            try {

                val request = Request.Builder()
                    .url(url)
                    .addHeader("X-App-Key", "RINGTONE_MASTER_V2_SECRET_2026")
                    .build()

                val response = httpClient.newCall(request).execute()

                val body = response.body()?.string() ?: return@Thread

                //  YENİ JSON FORMAT
                val jsonObject = org.json.JSONObject(body)
                val source = jsonObject.getString("source")
                val items = jsonObject.getJSONArray("data")

                val results = mutableListOf<VideoModel>()

                for (i in 0 until items.length()) {

                    val item = items.getJSONObject(i)
                    val snippet = item.getJSONObject("snippet")
                    val contentDetails = item.getJSONObject("contentDetails")
                    val isoDuration = contentDetails.getString("duration")
                    val durationSeconds = parseIsoDuration(isoDuration)

                    val videoId = item.getString("id")
                    val title = snippet.getString("title")
                    val channel = snippet.getString("channelTitle")
                    val thumbnail = snippet
                        .getJSONObject("thumbnails")
                        .getJSONObject("high")
                        .getString("url")

                    results.add(
                        VideoModel(
                            title = title,
                            uploader = channel,
                            url = "https://www.youtube.com/watch?v=$videoId",
                            thumbnailUrl = thumbnail,
                            duration = durationSeconds
                        )
                    )
                }
                runOnUiThread {

                    //  HOME = 2'li Grid
                    recyclerView.layoutManager =
                        androidx.recyclerview.widget.GridLayoutManager(this@MainActivity, 2)

                    android.util.Log.d("TOP50_SOURCE", "Top50 $source'den geldi")

                    recyclerView.adapter = HomeAdapter(
                        results,

                        onWatch = { video ->
                            startActivity(
                                Intent(this@MainActivity, VideoPlayerActivity::class.java)
                                    .putExtra("url", video.url)
                            )
                        },

                        onListen = { video ->

                            val trackList = results.map {
                                TrackEntity(
                                    playlistId = -1,
                                    title = it.title,
                                    uploader = it.uploader,
                                    streamUrl = it.url,
                                    thumbnailUrl = it.thumbnailUrl
                                )
                            }

                            val track = trackList.find { it.streamUrl == video.url }

                            if (track != null) {
                                playTrack(track, trackList)
                            }
                        },

                        onDownloadMp3 = { downloadFile(it, "_audio.m4a") },
                        onDownloadMp4 = { downloadFile(it, "_video.mp4") },
                        onAddPlaylist = { showPlaylistPicker(it) },
                        onGoDownloads = { refreshDownloadsList() }
                    )
                    loadingLayout.visibility = View.GONE
                }


            } catch (e: Exception) {
                e.printStackTrace()
                runOnUiThread {
                    //  HATA → loading kapat
                    loadingLayout.visibility = View.GONE
                }
            }
        }.start()
    }
    private fun performSearch(query: String) {
        txtToolbarTitle.text = "Search Results"
        txtToolbarSubtitle.text = query
        currentQuery = query
        searchResults.clear()

        Thread {
            try {

                val url =
                    "https://ringtone-production.up.railway.app/search?q=${java.net.URLEncoder.encode(query, "UTF-8")}"
                val request = Request.Builder()
                    .url(url)
                    .addHeader("X-App-Key", "RINGTONE_MASTER_V2_SECRET_2026")
                    .build()

                val response = httpClient.newCall(request).execute()


                //  403 kontrolü
                if (response.code() == 403) {
                    runOnUiThread {
                        Toast.makeText(
                            this@MainActivity,
                            "Unauthorized request",
                            Toast.LENGTH_SHORT
                        ).show()
                    }
                    return@Thread
                }

                // 429 kontrolü
                if (response.code() == 429) {
                    runOnUiThread {
                        Toast.makeText(
                            this@MainActivity,
                            "Too many searches. Please wait 1 minute.",
                            Toast.LENGTH_SHORT
                        ).show()
                    }
                    return@Thread
                }

                val body = response.body()?.string() ?: return@Thread

                val jsonObject = org.json.JSONObject(body)
                nextPageToken = jsonObject.optString("nextPageToken", null)
                val items = jsonObject.getJSONArray("data")


                for (i in 0 until items.length()) {

                    val item = items.getJSONObject(i)
                    val snippet = item.getJSONObject("snippet")

                    // id hem string hem object olabilir
                    val videoId = if (item.get("id") is String) {
                        item.getString("id")
                    } else {
                        item.getJSONObject("id").getString("videoId")
                    }

                    val title = snippet.getString("title")
                    val channel = snippet.getString("channelTitle")

                    val thumbnail = snippet
                        .getJSONObject("thumbnails")
                        .getJSONObject("high")
                        .getString("url")

                    searchResults.add(
                        VideoModel(
                            title = title,
                            uploader = channel,
                            url = "https://www.youtube.com/watch?v=$videoId",
                            thumbnailUrl = thumbnail,
                            duration = 0L
                        )
                    )
                }

                runOnUiThread {

                    recyclerView.layoutManager =
                        LinearLayoutManager(this@MainActivity)
                    recyclerView.addOnScrollListener(object : RecyclerView.OnScrollListener() {

                        override fun onScrolled(rv: RecyclerView, dx: Int, dy: Int) {

                            if (dy <= 0) return

                            val layoutManager = rv.layoutManager as LinearLayoutManager
                            val lastVisible = layoutManager.findLastVisibleItemPosition()

                            if (!isLoadingMore && lastVisible >= searchResults.size - 5) {

                                if (nextPageToken != null) {

                                    loadNextPage()

                                }
                            }
                        }
                    })

                    android.util.Log.d("SEARCH_RESULTS", "Results = ${searchResults.size}")

                    val trackList = searchResults.map {
                        TrackEntity(
                            playlistId = -1,
                            title = it.title,
                            uploader = it.uploader,
                            streamUrl = it.url,
                            thumbnailUrl = it.thumbnailUrl
                        )
                    }
                    recyclerView.adapter = SearchAdapter(
                        searchResults,

                        onWatch = { video ->
                            val intent = Intent(this, VideoPlayerActivity::class.java)
                            intent.putExtra("url", video.url)
                            startActivity(intent)
                        },

                        onListen = { video ->
                            val track = trackList.find { it.streamUrl == video.url }
                            if (track != null) {
                                playTrack(track, trackList)
                            }
                        },


                        onDownloadMp3 = { video ->
                            downloadFile(video, "_audio.m4a")
                        },


                        onDownloadMp4 = { video ->
                            downloadFile(video, "_video.mp4")
                        },

                        onAddPlaylist = { video ->
                            showPlaylistPicker(video)
                        },

                        onGoDownloads = {
                            refreshDownloadsList()
                        }
                    )
                }

            } catch (e: Exception) {
                e.printStackTrace()
            }
        }.start()
    }

    // DOWNLOADS KISMI


   fun refreshDownloadsList() {
        isDownloadsScreen = true
        txtToolbarTitle.text = "Downloads"
        txtToolbarSubtitle.text = "Your Collection"

        // Normal RecyclerView'ı gizle, ViewPager2'yi göster
        recyclerView.visibility = View.GONE
        downloadViewPager.visibility = View.VISIBLE
        tabContainer.visibility = View.VISIBLE
        downloadTabs.visibility = View.VISIBLE

        lifecycleScope.launch(Dispatchers.IO) {
            val downloads = db.dao().getDownloads()

            withContext(Dispatchers.Main) {
                allDownloads.clear()
                allDownloads.addAll(
                    downloads.map {
                        DownloadedItem(
                            java.io.File(it.path),
                            it.isAudio,
                            it.thumbnailUrl,
                            it.duration
                        )
                    }
                )

                // ViewPager2 adapter bağla
                downloadViewPager.adapter = DownloadsPagerAdapter(this@MainActivity, allDownloads)

                // TabLayout + ViewPager2 senkronize et (kaydırmalı!)
                TabLayoutMediator(downloadTabs, downloadViewPager) { tab, position ->
                    tab.text = if (position == 0) "\uD83C\uDFB5 Audio" else "\uD83C\uDFA5 Videos"
                }.attach()
            }
        }
    }

    // DownloadsPagerAdapter'ın erişebilmesi için public metodlar
    fun onDownloadPlay(clickedItem: DownloadedItem) {
        if (clickedItem.isAudio) {
            val audioList = allDownloads
                .filter { it.isAudio }
                .map {
                    TrackEntity(
                        playlistId = -1,
                        title = it.file.name,
                        streamUrl = it.file.absolutePath,
                        uploader = "Local file",
                        thumbnailUrl = it.thumbnailUrl ?: ""
                    )
                }
            val index = audioList.indexOfFirst {
                it.streamUrl == clickedItem.file.absolutePath
            }
            if (index != -1) {
                playTrack(audioList[index], audioList)
            }
        } else {
            openLocalVideo(clickedItem.file)
        }
    }

    fun onDownloadDelete(item: DownloadedItem) {
        lifecycleScope.launch(Dispatchers.IO) {
            db.dao().deleteDownload(item.file.absolutePath)
