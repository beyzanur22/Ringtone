package com.example.ringtonemasterv2

import android.app.PictureInPictureParams
import android.content.ComponentName
import android.content.Context
import android.content.Intent
import android.content.ServiceConnection
import android.content.res.Configuration
import android.os.Build
import android.os.Bundle
import android.os.IBinder
import android.util.Log
import android.util.Rational
import android.view.View
import android.widget.ImageButton
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.lifecycle.lifecycleScope
import androidx.media3.common.MediaItem
import androidx.media3.common.MediaMetadata
import androidx.media3.common.util.UnstableApi
import androidx.media3.datasource.DefaultHttpDataSource
import androidx.media3.exoplayer.ExoPlayer
import androidx.media3.exoplayer.source.ProgressiveMediaSource
import androidx.media3.ui.PlayerView
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.launch
import kotlinx.coroutines.withContext
import java.io.File

@UnstableApi
class VideoPlayerActivity : AppCompatActivity() {

    private var videoService: VideoService? = null
    private var isBound = false
    private lateinit var playerView: PlayerView
    private lateinit var backButton: ImageButton

    private val connection = object : ServiceConnection {
        override fun onServiceConnected(name: ComponentName?, service: IBinder?) {
            val binder = service as VideoService.VideoBinder
            videoService = binder.getService()
            isBound = true
            
            // Servisteki player'ı UI'a bağla
            playerView.player = videoService?.getPlayer()
            
            // Eğer URL zaten varsa (Activity yeni açıldıysa) oynatmayı başlat
            checkIntentAndPlay()
        }

        override fun onServiceDisconnected(name: ComponentName?) {
            videoService = null
            isBound = false
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_video_player)

        playerView = findViewById(R.id.playerView)
        backButton = findViewById(R.id.backButton)

        backButton.setOnClickListener { finish() }

        // Servisi başlat ve bağla
        val intent = Intent(this, VideoService::class.java)
        startService(intent) // Arka planda yaşaması için önemli
        bindService(intent, connection, Context.BIND_AUTO_CREATE)
    }

    override fun onNewIntent(intent: Intent?) {
        super.onNewIntent(intent)
        setIntent(intent)
        checkIntentAndPlay()
    }

    private fun checkIntentAndPlay() {
        val youtubeUrl = intent.getStringExtra("url")
        val localPath = intent.getStringExtra("path")
        val title = intent.getStringExtra("title") ?: "Video Master"

        if (!localPath.isNullOrEmpty()) {
            playLocalVideo(localPath, title)
        } else if (!youtubeUrl.isNullOrEmpty()) {
            fetchAndPlayYoutubeVideo(youtubeUrl, title)
        }
    }

    private fun playLocalVideo(path: String, title: String) {
        val file = File(path)
        if (file.exists()) {
            val metadata = MediaMetadata.Builder()
                .setTitle(title)
                .build()
            videoService?.play(file.toURI().toString(), metadata)
        } else {
            Toast.makeText(this, "Dosya bulunamadı", Toast.LENGTH_SHORT).show()
            finish()
        }
    }

    private fun fetchAndPlayYoutubeVideo(youtubeUrl: String, title: String) {
        lifecycleScope.launch(Dispatchers.IO) {
            try {
                val uri = android.net.Uri.parse(youtubeUrl)
                val videoId = uri.getQueryParameter("v") ?: uri.lastPathSegment ?: return@launch

                // VideoApi üzerinden link al (Mevcut logic korunuyor)
                var videoUrl = kotlinx.coroutines.withTimeoutOrNull(15000L) {
                    VideoApi(this@VideoPlayerActivity).getVideoUrl(videoId)
                }

                if (videoUrl.isNullOrEmpty()) {
                    videoUrl = "https://ringtone-production.up.railway.app/stream/video?videoId=$videoId"
                }

                withContext(Dispatchers.Main) {
                    val metadata = MediaMetadata.Builder()
                        .setTitle(title)
                        .setArtist("Ringtone Master")
                        .build()
                    videoService?.play(videoUrl!!, metadata)
                }
            } catch (e: Exception) {
                Log.e("VIDEO_PLAYER", "Error: ${e.message}")
            }
        }
    }

    // ========== PICTURE IN PICTURE (PiP) LOGIC ==========

    override fun onUserLeaveHint() {
        super.onUserLeaveHint()
        // Kullanıcı Home veya Recents'e bastığında PiP'e geç
        if (videoService?.getPlayer()?.isPlaying == true) {
            enterPipMode()
        }
    }

    private fun enterPipMode() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            // Sabit 16:9 en-boy oranı
            val params = PictureInPictureParams.Builder()
                .setAspectRatio(Rational(16, 9))
                .build()
            enterPictureInPictureMode(params)
        }
    }

    override fun onPictureInPictureModeChanged(isInPictureInPictureMode: Boolean, newConfig: Configuration) {
        super.onPictureInPictureModeChanged(isInPictureInPictureMode, newConfig)
        if (isInPictureInPictureMode) {
            // PiP modunda kontrolleri gizle
            backButton.visibility = View.GONE
            playerView.useController = false
        } else {
            // Tam ekrana dönünce kontrolleri geri getir
            backButton.visibility = View.VISIBLE
            playerView.useController = true
        }
    }

    override fun onStop() {
        super.onStop()
        // Eğer PiP modunda değilsek ve kullanıcı uygulamadan tamamen çıktıysa
        // Servis kilit ekranında devam edecek, ama Activity durabilir.
    }

    override fun onDestroy() {
        if (isBound) {
            unbindService(connection)
            isBound = false
        }
        super.onDestroy()
    }
}